{
  "title": "typst-d2-mcp · overview",
  "uid": "typst-d2-mcp-overview",
  "tags": ["typst-d2-mcp"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "selected": true, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "regex": "",
        "multi": false,
        "includeAll": false
      },
      {
        "name": "namespace",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(typst_d2_mcp_compile_total, namespace)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Compile rate by result",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "drawStyle": "bars", "stacking": { "mode": "normal" } } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (result) (rate(typst_d2_mcp_compile_total{namespace=~\"$namespace\"}[5m]))",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ],
      "description": "Compiles per second by terminal result. Stacked: ok / fail / quota_exceeded / timeout / too_large."
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Success rate (5m)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.9 },
              { "color": "green", "value": 0.99 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        {
          "expr": "sum(rate(typst_d2_mcp_compile_total{namespace=~\"$namespace\",result=\"ok\"}[5m])) / sum(rate(typst_d2_mcp_compile_total{namespace=~\"$namespace\"}[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Compiles (24h)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [
        {
          "expr": "sum(increase(typst_d2_mcp_compile_total{namespace=~\"$namespace\"}[24h]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Compile duration (p50 / p95)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le) (rate(typst_d2_mcp_compile_duration_seconds_bucket{namespace=~\"$namespace\"}[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(typst_d2_mcp_compile_duration_seconds_bucket{namespace=~\"$namespace\"}[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "put_file rate by result",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "stacking": { "mode": "normal" } } } },
      "targets": [
        {
          "expr": "sum by (result) (rate(typst_d2_mcp_put_file_total{namespace=~\"$namespace\"}[5m]))",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Auth rejections / sec",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        {
          "expr": "sum(rate(typst_d2_mcp_auth_rejected_total{namespace=~\"$namespace\"}[5m]))",
          "legendFormat": "rejected",
          "refId": "A"
        }
      ],
      "description": "Spike here is either a misconfigured client or a probe. Alert worth wiring up."
    },
    {
      "id": 7,
      "type": "histogram",
      "title": "Compile input size (bytes)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "expr": "sum by (le) (rate(typst_d2_mcp_compile_input_bytes_bucket{namespace=~\"$namespace\"}[15m]))",
          "format": "heatmap",
          "refId": "A"
        }
      ]
    }
  ]
}
