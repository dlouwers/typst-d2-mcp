# Test-env Secret template. Sealed Secrets are bound to (namespace,
# name) by the bitnami controller, so the test seal cannot decrypt in
# prod and vice versa — keep them as separate files even though the
# schema is identical.
apiVersion: v1
kind: Secret
metadata:
  name: typst-d2-mcp-secrets
  namespace: typst-d2-mcp-test
type: Opaque
stringData:
  TYPST_D2_MCP_GITHUB_CLIENT_ID: "Iv1.XXXXXXXXXXXXXXXX"
  TYPST_D2_MCP_GITHUB_CLIENT_SECRET: "github_pat_XXXXXXXXXXXXXXXXXXXXXX"
  TYPST_D2_MCP_METRICS_BEARER: "REPLACE_WITH_OPENSSL_RAND_HEX_32"
