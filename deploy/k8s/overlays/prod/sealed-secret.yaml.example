# Template — DO NOT commit a real plaintext Secret. Use this as the
# input to `kubeseal`, then commit only the resulting sealed-secret.yaml
# in this directory.
#
#   kubeseal --controller-namespace kube-system \
#            --format yaml \
#            < sealed-secret.yaml.input \
#            > sealed-secret.yaml
#
# See deploy/k8s/README.md for the full sealing workflow including
# how to rotate individual keys.
apiVersion: v1
kind: Secret
metadata:
  name: typst-d2-mcp-secrets
  namespace: typst-d2-mcp
type: Opaque
stringData:
  # GitHub OAuth app (https://github.com/settings/developers).
  # Callback URL must match TYPST_D2_MCP_PUBLIC_URL + /auth/github/callback.
  TYPST_D2_MCP_GITHUB_CLIENT_ID: "Iv1.XXXXXXXXXXXXXXXX"
  TYPST_D2_MCP_GITHUB_CLIENT_SECRET: "github_pat_XXXXXXXXXXXXXXXXXXXXXX"

  # Bearer token Prometheus uses when scraping /metrics. Generate
  # a fresh random string per environment:
  #   openssl rand -hex 32
  TYPST_D2_MCP_METRICS_BEARER: "REPLACE_WITH_OPENSSL_RAND_HEX_32"
